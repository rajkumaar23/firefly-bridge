FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /portfolio-sync ./cmd/portfolio-sync

FROM alpine:3

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /portfolio-sync /usr/local/bin/portfolio-sync

ENTRYPOINT ["/usr/local/bin/portfolio-sync"]
